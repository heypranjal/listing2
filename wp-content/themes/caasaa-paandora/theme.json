{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "navy-deep", "color": "#0D0F1C", "name": "Deep Navy" },
        { "slug": "navy-mid", "color": "#12141F", "name": "Mid Navy" },
        { "slug": "navy-light", "color": "#1A1D2E", "name": "Light Navy" },
        { "slug": "gold", "color": "#C9A15C", "name": "Gold" },
        { "slug": "gold-light", "color": "#E2BE82", "name": "Gold Light" },
        { "slug": "cream", "color": "#F5EFE6", "name": "Cream" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" },
        { "slug": "charcoal", "color": "#2A2D3E", "name": "Charcoal" }
      ],
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "gradients": [
        {
          "slug": "navy-to-transparent",
          "gradient": "linear-gradient(to top, #0D0F1C 0%, rgba(13,15,28,0.7) 50%, rgba(13,15,28,0.1) 100%)",
          "name": "Navy to Transparent"
        },
        {
          "slug": "gold-shine",
          "gradient": "linear-gradient(135deg, #C9A15C 0%, #E2BE82 50%, #C9A15C 100%)",
          "name": "Gold Shine"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Playfair Display', 'Cormorant Garamond', Georgia, serif",
          "slug": "display",
          "name": "Display Serif"
        },
        {
          "fontFamily": "'Inter', 'Lato', Arial, sans-serif",
          "slug": "body",
          "name": "Body Sans"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "0.75rem", "name": "Extra Small" },
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "base", "size": "1rem", "name": "Base" },
        { "slug": "lg", "size": "1.125rem", "name": "Large" },
        { "slug": "xl", "size": "1.25rem", "name": "XL" },
        { "slug": "2xl", "size": "1.5rem", "name": "2XL" },
        { "slug": "3xl", "size": "2rem", "name": "3XL" },
        { "slug": "4xl", "size": "2.5rem", "name": "4XL" },
        { "slug": "5xl", "size": "3.5rem", "name": "5XL" },
        { "slug": "6xl", "size": "5rem", "name": "6XL" }
      ],
      "customFontSize": true,
      "lineHeight": true,
      "letterSpacing": true
    },
    "spacing": {
      "spacingScale": {
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem",
        "operator": "*",
        "increment": 1.5,
        "steps": 7
      },
      "spacingSizes": [
        { "slug": "20", "size": "0.5rem", "name": "Spacing 20" },
        { "slug": "30", "size": "1rem", "name": "Spacing 30" },
        { "slug": "40", "size": "1.5rem", "name": "Spacing 40" },
        { "slug": "50", "size": "2.5rem", "name": "Spacing 50" },
        { "slug": "60", "size": "4rem", "name": "Spacing 60" },
        { "slug": "70", "size": "6rem", "name": "Spacing 70" },
        { "slug": "80", "size": "8rem", "name": "Spacing 80" }
      ],
      "padding": true,
      "margin": true,
      "blockGap": true,
      "customSpacingSize": true
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "presets": [
        {
          "slug": "gold-glow",
          "shadow": "0 0 30px rgba(201, 161, 92, 0.2)",
          "name": "Gold Glow"
        },
        {
          "slug": "card-shadow",
          "shadow": "0 10px 40px rgba(0,0,0,0.4)",
          "name": "Card Shadow"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#0D0F1C",
      "text": "#F5EFE6"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "700",
          "letterSpacing": "0.02em",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "600",
          "letterSpacing": "0.02em",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": { "text": "#C9A15C" },
        ":hover": {
          "color": { "text": "#E2BE82" }
        }
      },
      "button": {
        "color": {
          "background": "#C9A15C",
          "text": "#0D0F1C"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontWeight": "600",
          "letterSpacing": "0.1em"
        },
        "border": { "radius": "50px" },
        ":hover": {
          "color": {
            "background": "#E2BE82",
            "text": "#0D0F1C"
          }
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "front-page", "title": "Front Page", "postTypes": ["page"] }
  ]
}
